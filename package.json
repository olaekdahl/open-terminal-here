{
  "name": "open-terminal-here",
  "displayName": "Open Terminal Here",
  "description": "Open a terminal (PowerShell, WSL, or Command Prompt) from the Explorer context menu, using the selected folder as the working directory.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openTerminalHere.powershell",
        "title": "Open PowerShell Here"
      },
      {
        "command": "openTerminalHere.pwsh",
        "title": "Open PowerShell 7 Here"
      },
      {
        "command": "openTerminalHere.cmd",
        "title": "Open Command Prompt Here"
      },
      {
        "command": "openTerminalHere.gitbash",
        "title": "Open Git Bash Here"
      },
      {
        "command": "openTerminalHere.wsl",
        "title": "Open WSL Here"
      },
      {
        "command": "openTerminalHere.zsh",
        "title": "Open Zsh Here"
      },
      {
        "command": "openTerminalHere.bash",
        "title": "Open Bash Here"
      },
      {
        "command": "openTerminalHere.fish",
        "title": "Open Fish Here"
      },
      {
        "command": "openTerminalHere.sh",
        "title": "Open sh Here"
      },
      {
        "command": "openTerminalHere.refresh",
        "title": "Refresh Available Shells",
        "category": "Open Terminal Here"
      }
    ],
    "submenus": [
      {
        "id": "openTerminalHere.submenu",
        "label": "Open Terminal Here"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "openTerminalHere.submenu",
          "group": "navigation",
          "when": "openTerminalHere.hasShells"
        }
      ],
      "openTerminalHere.submenu": [
        {
          "command": "openTerminalHere.powershell",
          "when": "openTerminalHere.powershellAvailable"
        },
        {
          "command": "openTerminalHere.pwsh",
          "when": "openTerminalHere.pwshAvailable"
        },
        {
          "command": "openTerminalHere.cmd",
          "when": "openTerminalHere.cmdAvailable"
        },
        {
          "command": "openTerminalHere.gitbash",
          "when": "openTerminalHere.gitbashAvailable"
        },
        {
          "command": "openTerminalHere.wsl",
          "when": "openTerminalHere.wslAvailable"
        },
        {
          "command": "openTerminalHere.zsh",
          "when": "openTerminalHere.zshAvailable"
        },
        {
          "command": "openTerminalHere.bash",
          "when": "openTerminalHere.bashAvailable"
        },
        {
          "command": "openTerminalHere.fish",
          "when": "openTerminalHere.fishAvailable"
        },
        {
          "command": "openTerminalHere.sh",
          "when": "openTerminalHere.shAvailable"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
